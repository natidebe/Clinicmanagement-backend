# Django
DJANGO_SECRET_KEY=your-django-secret-key
DEBUG=False
ALLOWED_HOSTS=your-domain.com

# Supabase
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key
SUPABASE_JWT_SECRET=your-jwt-secret

# Database (Supabase connection pooler)
DB_USER=postgres
DB_PASSWORD=your-db-password
DB_HOST=db.your-project.supabase.co
DB_PORT=6543
DB_NAME=postgres

# Redis (for Celery)
REDIS_URL=redis://localhost:6379/0

# Chapa payment gateway
# Get test keys at: https://dashboard.chapa.co → API Keys
# Register webhook URL: https://your-domain.com/api/billing/webhook/chapa/
CHAPA_SECRET_KEY=CHASECK_TEST-xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
CHAPA_WEBHOOK_SECRET=your-webhook-secret

# CORS (comma-separated)
CORS_ALLOWED_ORIGINS=https://your-frontend.com
