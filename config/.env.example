# Copy this file to .env and fill in your values. Never commit .env to version control.

DJANGO_SECRET_KEY=your-long-random-secret-key-here
DEBUG=True
ALLOWED_HOSTS=localhost,127.0.0.1

# PostgreSQL / Supabase
DB_NAME=postgres
DB_USER=postgres.<your-supabase-project-ref>
DB_PASSWORD=your-database-password
DB_HOST=aws-0-<region>.pooler.supabase.com
DB_PORT=6543

# Supabase → Settings → API
SUPABASE_URL=https://<your-project-ref>.supabase.co
SUPABASE_SERVICE_ROLE_KEY=your-supabase-service-role-key

# Supabase → Settings → API → JWT Secret
SUPABASE_JWT_SECRET=your-supabase-jwt-secret

# CORS: comma-separated list of allowed frontend origins (only needed when DEBUG=False)
# CORS_ALLOWED_ORIGINS=https://yourfrontend.com
